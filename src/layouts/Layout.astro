---
import '../styles/global.css'
interface Props {
  title: string
}
const { title } = Astro.props
---
<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-black text-white font-['Inter'] antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-8 py-6 mix-blend-difference">
      <a href={`${import.meta.env.BASE_URL}`} class="text-sm tracking-widest uppercase text-white">Your Name</a>
      <div class="flex gap-8 text-sm tracking-widest uppercase text-white">
        <a href={`${import.meta.env.BASE_URL}destinations/`} class="hover:opacity-50 transition-opacity">Destinations</a>
        <a href={`${import.meta.env.BASE_URL}about/`} class="hover:opacity-50 transition-opacity">About</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
