---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Your Name — Travel">
  <!-- Hero: 全屏封面大图 -->
  <section class="relative h-screen w-full overflow-hidden">
    <img
      src={`${import.meta.env.BASE_URL}images/wedding-1.jpg`}
      alt="Cover"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40" />
    <div class="absolute bottom-16 left-8 md:left-16">
      <p class="text-xs tracking-widest uppercase text-white/60 mb-3">Photographs by</p>
      <h1 class="text-5xl md:text-7xl font-light tracking-tight text-white">Your Name</h1>
      <p class="mt-4 text-lg text-white/60 font-light">Moments I've captured</p>
    </div>
    <a
      href={`${import.meta.env.BASE_URL}destinations/`}
      class="absolute bottom-16 right-8 md:right-16 text-xs tracking-widest uppercase text-white/60 hover:text-white transition-colors"
    >
      View all →
    </a>
  </section>

  <!-- Featured: 三个场景预览 -->
  <section class="px-8 md:px-16 py-24">
    <p class="text-xs tracking-widest uppercase text-white/40 mb-12">Featured</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href={`${import.meta.env.BASE_URL}destinations/yueyang-bbq/`} class="group block">
        <div class="overflow-hidden aspect-[3/4] mb-4">
          <img
            src={`${import.meta.env.BASE_URL}images/yueyang-bbq-1.jpg`}
            alt="岳阳烧烤"
            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
          />
        </div>
        <p class="text-sm tracking-wide">Yueyang BBQ Night</p>
        <p class="text-xs text-white/40 mt-1">岳阳烧烤</p>
      </a>
      <a href={`${import.meta.env.BASE_URL}destinations/wedding/`} class="group block">
        <div class="overflow-hidden aspect-[3/4] mb-4">
          <img
            src={`${import.meta.env.BASE_URL}images/wedding-2.jpg`}
            alt="婚纱照"
            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
          />
        </div>
        <p class="text-sm tracking-wide">Wedding Portrait</p>
        <p class="text-xs text-white/40 mt-1">婚纱照</p>
      </a>
      <a href={`${import.meta.env.BASE_URL}destinations/vintage/`} class="group block">
        <div class="overflow-hidden aspect-[3/4] mb-4">
          <img
            src={`${import.meta.env.BASE_URL}images/vintage-1.jpg`}
            alt="怀旧老照片"
            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
          />
        </div>
        <p class="text-sm tracking-wide">Vintage Memories</p>
        <p class="text-xs text-white/40 mt-1">怀旧老照片</p>
      </a>
    </div>
  </section>
</Layout>
